---
import '../styles/index.css';
import MainHead from '../components/MainHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/ui/BackToTop.astro';

interface OGData {
  title?: string;
  description?: string;
  image?: string;
}

interface Props {
  title?: string;
  structuredData?: object | object[];
  meta?: string;
  liturgy?: boolean;
  ogData?: OGData;
}

const { title, meta, structuredData, liturgy, ogData } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <script
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="e0da0de5-9cf3-4c9d-af46-957fd58158c5"></script>

    <MainHead
      liturgy={liturgy}
      title={title}
      meta={meta}
      structuredData={structuredData}
      ogData={ogData}
    />

    <!-- Always dark -->
    <script is:inline>
      document.documentElement.classList.add('dark');
      document.addEventListener('astro:after-swap', () => {
        document.documentElement.classList.add('dark');
      });
    </script>
  </head>
  <body
    class="relative min-h-screen overflow-x-hidden bg-bg-primary font-bodyfont text-white"
  >
    <!-- Background effects -->
    <div class="fixed inset-0 -z-10 overflow-hidden">
      <!-- Gradient spotlight from top -->
      <div class="spotlight absolute inset-0"></div>

      <!-- Interactive cursor-following glow -->
      <div id="cursor-glow" class="cursor-glow absolute inset-0"></div>

      <!-- Grid pattern -->
      <div class="grid-pattern absolute inset-0 opacity-50"></div>

      <!-- Ambient glow orbs - more subtle and refined -->
      <div
        class="bg-accent/[0.03] absolute -left-32 top-0 h-[500px] w-[500px] rounded-full blur-[100px] md:-left-20 md:h-[600px] md:w-[600px] md:blur-[120px]"
      >
      </div>
      <div
        class="bg-accent/[0.04] absolute -right-32 top-1/3 h-[400px] w-[400px] rounded-full blur-[100px] md:-right-20 md:h-[500px] md:w-[500px] md:blur-[130px]"
      >
      </div>
      <div
        class="bg-accent/[0.02] absolute -bottom-32 left-1/4 h-[350px] w-[350px] rounded-full blur-[80px] md:h-[400px] md:w-[400px] md:blur-[100px]"
      >
      </div>

      <!-- Additional subtle glow for depth -->
      <div
        class="bg-accent/[0.015] absolute left-1/2 top-1/2 h-[300px] w-[800px] -translate-x-1/2 -translate-y-1/2 rounded-full blur-[100px]"
      >
      </div>

      <!-- Noise overlay -->
      <div class="noise-overlay absolute inset-0"></div>
    </div>

    <!-- {!liturgy && <Header />} -->
    <Header />

    <main
      class="relative mx-auto my-10 min-h-screen max-w-6xl px-6 pt-10 md:my-16 lg:px-8 xl:px-0"
    >
      <slot />
    </main>

    <Footer />
    <BackToTop />

    <!-- Cursor-following glow tracker -->
    <script is:inline>
      document.addEventListener('astro:page-load', () => {
        (() => {
          const reduceMotion = window.matchMedia(
            '(prefers-reduced-motion: reduce)',
          ).matches;
          const finePointer = window.matchMedia('(pointer: fine)').matches;
          if (reduceMotion || !finePointer) return;

          const glow = document.getElementById('cursor-glow');
          if (!glow) return;

          // Target = latest mouse position; current = smoothed position.
          let targetX = window.innerWidth / 2;
          let targetY = window.innerHeight / 2;
          let currentX = targetX;
          let currentY = targetY;
          let visible = false;
          let raf = 0;

          const render = () => {
            // Ease current toward target for a trailing, fluid feel.
            currentX += (targetX - currentX) * 0.12;
            currentY += (targetY - currentY) * 0.12;
            glow.style.setProperty('--glow-x', currentX + 'px');
            glow.style.setProperty('--glow-y', currentY + 'px');
            raf = requestAnimationFrame(render);
          };

          window.addEventListener(
            'pointermove',
            (e) => {
              targetX = e.clientX;
              targetY = e.clientY;
              if (!visible) {
                visible = true;
                glow.style.opacity = '1';
              }
              if (!raf) raf = requestAnimationFrame(render);
            },
            { passive: true },
          );

          window.addEventListener('blur', () => {
            glow.style.opacity = '0';
            visible = false;
            if (raf) {
              cancelAnimationFrame(raf);
              raf = 0;
            }
          });
        })();
      });
    </script>
  </body>
</html>
