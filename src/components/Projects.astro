---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import turncateString from '../utils/turncateString';

const allProjects: CollectionEntry<'projects'>[] = (
  await getCollection('projects')
).filter((project) => !project.data.isDraft);

const sortByDate = (
  a: CollectionEntry<'projects'>,
  b: CollectionEntry<'projects'>,
) => b.data.pubDate.getTime() - a.data.pubDate.getTime();

// Prefer explicitly featured projects, fall back to the most recent ones.
const featured = allProjects.filter((project) => project.data.featured);
const featuredProjects = (featured.length ? featured : allProjects)
  .sort(sortByDate)
  .slice(0, 4);
---

<section id="projects" class="scroll-mt-20 bg-bg-secondary py-16 md:py-24">
  <div class="container-page">
    <!-- Section header -->
    <div
      class="mb-10 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between"
    >
      <div>
        <p class="eyebrow">Featured Projects</p>
        <h2 class="mt-2 text-2xl font-bold text-white md:text-3xl">
          Things I've Built
        </h2>
      </div>
      <a
        href="/projects"
        class="group inline-flex items-center gap-2 text-sm font-medium text-white transition-colors hover:text-accent"
      >
        View all projects
        <svg
          class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>

    <!-- Cards -->
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        featuredProjects.map((project) => (
          <article class="hover-lift group overflow-hidden rounded-xl border border-border bg-bg-card">
            <a href={`/projects/${project.id}`} class="flex h-full flex-col">
              <div class="aspect-[16/11] overflow-hidden border-b border-border bg-bg-secondary">
                <Image
                  class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
                  width={480}
                  height={330}
                  src={project.data.images[0].src}
                  alt={project.data.images[0].alt}
                />
              </div>

              <div class="flex flex-1 flex-col p-5">
                <h3 class="text-base font-semibold text-white transition-colors group-hover:text-accent">
                  {project.data.title}
                </h3>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-text-muted">
                  {turncateString(
                    project.data.shortDesc || project.data.description,
                    90,
                  )}
                </p>
                {project.data.technology?.length > 0 && (
                  <p class="mt-4 text-xs font-medium text-text-muted">
                    {project.data.technology.slice(0, 4).join(' • ')}
                  </p>
                )}
              </div>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
