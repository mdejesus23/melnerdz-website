---
interface Props {
  title: string;
  url: string;
  currentPath?: string;
}

const { title, url, currentPath = '' } = Astro.props;

// Normalize paths for comparison
const normalizedUrl = url === '/' ? '/' : url.replace(/\/+$/, '');
const normalizedPath =
  currentPath === '/' ? '/' : currentPath.replace(/\/+$/, '');
const isActive =
  normalizedUrl === '/'
    ? normalizedPath === '/'
    : normalizedPath === normalizedUrl ||
      normalizedPath.startsWith(`${normalizedUrl}/`);
---

<a
  href={url}
  aria-current={isActive ? 'page' : undefined}
  class:list={[
    'relative px-3 py-2 text-sm font-medium transition-colors lg:px-4',
    isActive ? 'text-white' : 'text-text-muted hover:text-white',
  ]}
>
  {title}
  {
    isActive && (
      <span class="absolute -bottom-0.5 left-1/2 h-0.5 w-5 -translate-x-1/2 rounded-full bg-accent" />
    )
  }
</a>
