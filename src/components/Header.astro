---
import { navLinks } from '@/data/navLinks';
import NavLink from './ui/NavLink.astro';
import ThemeToggle from './ui/ThemeToggle.astro';
import MenuOpen from './ui/icons/MenuOpen.astro';
---

<header
  id="main-header"
  class="fixed left-0 right-0 top-0 z-50 border-b border-transparent bg-bg-primary/80 backdrop-blur-md transition-colors duration-300"
>
  <div class="container-page flex h-16 items-center justify-between gap-4">
    <!-- Logo -->
    <a
      href="/"
      class="font-logofont text-2xl font-bold tracking-tight text-white"
      aria-label="Melnard De Jesus — home"
    >
      MJ
    </a>

    <!-- Desktop navigation (centred) -->
    <nav
      class="absolute left-1/2 hidden -translate-x-1/2 items-center md:flex"
      aria-label="Main navigation"
    >
      {
        navLinks.map((link) => (
          <NavLink
            title={link.title}
            url={link.url}
            currentPath={Astro.url.pathname}
          />
        ))
      }
    </nav>

    <!-- Right side controls -->
    <div class="flex items-center gap-2">
      <ThemeToggle />
      <button
        id="mobile-menu"
        class="flex h-10 w-10 flex-col items-center justify-center rounded-full border border-border transition-colors hover:border-accent md:hidden"
        aria-controls="navbar-collapse"
        aria-label="Toggle navigation"
        aria-expanded="false"
      >
        <MenuOpen />
      </button>
    </div>
  </div>
</header>

<!-- Mobile navigation -->
<nav
  id="navbar-collapse"
  class="fixed inset-0 z-40 flex translate-x-full flex-col bg-bg-primary transition-transform duration-300 ease-in-out md:hidden"
  aria-label="Mobile navigation"
>
  <div class="flex flex-1 flex-col items-center justify-center gap-7 p-8">
    {
      navLinks.map((link) => (
        <a
          href={link.url}
          class="nav-mobile-link text-2xl font-semibold text-white transition-colors hover:text-accent"
        >
          {link.title}
        </a>
      ))
    }
  </div>

  <div class="flex justify-center gap-5 border-t border-border p-8">
    <a
      href="https://github.com/mdejesus23"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="GitHub"
      class="text-text-muted transition-colors hover:text-accent"
    >
      <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
        <path
          d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
        ></path>
      </svg>
    </a>
    <a
      href="https://www.linkedin.com/in/melnard-de-jesus-279132278"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="LinkedIn"
      class="text-text-muted transition-colors hover:text-accent"
    >
      <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
        <path
          d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"
        ></path>
      </svg>
    </a>
    <a
      href="https://www.facebook.com/dejesusmelnard"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Facebook"
      class="text-text-muted transition-colors hover:text-accent"
    >
      <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
        <path
          d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
        ></path>
      </svg>
    </a>
  </div>
</nav>

<script>
  document.addEventListener('astro:page-load', () => {
    const header = document.getElementById('main-header');
    const toggleButton = document.getElementById('mobile-menu');
    const mobileNav = document.getElementById('navbar-collapse');
    const mobileLinks = document.querySelectorAll('.nav-mobile-link');

    // Add a hairline border once the page is scrolled
    const handleScroll = () => {
      if (!header) return;
      header.classList.toggle('border-border', window.scrollY > 8);
      header.classList.toggle('border-transparent', window.scrollY <= 8);
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();

    const closeMenu = () => {
      if (!toggleButton || !mobileNav) return;
      toggleButton.classList.remove('change');
      toggleButton.setAttribute('aria-expanded', 'false');
      mobileNav.classList.add('translate-x-full');
      document.body.style.overflow = '';
    };

    if (toggleButton && mobileNav) {
      toggleButton.addEventListener('click', () => {
        const isOpen = !mobileNav.classList.contains('translate-x-full');
        if (isOpen) {
          closeMenu();
        } else {
          toggleButton.classList.add('change');
          toggleButton.setAttribute('aria-expanded', 'true');
          mobileNav.classList.remove('translate-x-full');
          document.body.style.overflow = 'hidden';
        }
      });

      mobileLinks.forEach((link) => link.addEventListener('click', closeMenu));

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeMenu();
      });
    }
  });
</script>
