---
import { Image } from 'astro:assets';
import profilePicture from '../images/mdj.png';

const socials = [
  {
    label: 'GitHub',
    url: 'https://github.com/mdejesus23',
    path: 'M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z',
  },
  {
    label: 'LinkedIn',
    url: 'https://www.linkedin.com/in/melnard-de-jesus-279132278',
    path: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z',
  },
  {
    label: 'Facebook',
    url: 'https://www.facebook.com/dejesusmelnard',
    path: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z',
  },
];
---

<section class="container-page py-16 md:py-24 lg:py-28">
  <div
    class="grid grid-cols-1 items-center gap-12 md:grid-cols-2 md:gap-10 lg:gap-16"
  >
    <!-- Copy -->
    <div class="order-2 md:order-1">
      <p class="eyebrow animate-fade-in-up opacity-0">
        Hi, I'm Melnard De Jesus
      </p>

      <h1
        class="mt-4 animate-fade-in-up text-4xl font-bold leading-[1.12] tracking-tight text-white opacity-0 delay-100 sm:text-5xl lg:text-[3.4rem]"
      >
        I build clean, fast and functional web apps.
      </h1>

      <p
        class="mt-6 max-w-md animate-fade-in-up text-base leading-relaxed text-text-muted opacity-0 delay-200"
      >
        Fullstack developer specializing in JavaScript, building modern web and
        mobile experiences.
      </p>

      <!-- CTAs -->
      <div
        class="mt-8 flex animate-fade-in-up flex-wrap items-center gap-3 opacity-0 delay-300"
      >
        <a
          href="/projects"
          class="group inline-flex items-center gap-2 rounded-lg bg-primary px-5 py-3 text-sm font-semibold text-primary-foreground transition-colors hover:bg-primary-hover"
        >
          View My Projects
          <svg
            class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>

        <a
          href="/mdj-resume-standard.pdf"
          target="_blank"
          class="group inline-flex items-center gap-2 rounded-lg border border-border bg-bg-card px-5 py-3 text-sm font-semibold text-white transition-colors hover:border-accent hover:text-accent"
        >
          Download CV
          <svg
            class="h-4 w-4 transition-transform duration-300 group-hover:translate-y-0.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
          </svg>
        </a>
      </div>

      <!-- Social row -->
      <div
        class="mt-10 flex animate-fade-in-up items-center gap-5 opacity-0 delay-400"
      >
        <span class="text-sm font-medium text-text-muted">Let's connect</span>
        <div class="flex items-center gap-4">
          {
            socials.map((social) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={social.label}
                class="text-text-muted transition-colors hover:text-accent"
              >
                <svg class="h-[18px] w-[18px]" fill="currentColor" viewBox="0 0 24 24">
                  <path d={social.path} />
                </svg>
              </a>
            ))
          }
          <a
            href="/contact"
            aria-label="Email"
            class="text-text-muted transition-colors hover:text-accent"
          >
            <svg
              class="h-[18px] w-[18px]"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Portrait panel -->
    <div class="relative order-1 animate-fade-in opacity-0 md:order-2">
      <!-- Dotted decoration -->
      <div
        class="dot-grid pointer-events-none absolute -right-2 top-1/4 hidden h-32 w-24 lg:block"
        aria-hidden="true"
      >
      </div>

      <figure
        class="relative ml-auto aspect-[4/5] w-full max-w-sm overflow-hidden rounded-2xl bg-[#e9ebf5] dark:bg-[#16203a] md:max-w-none"
      >
        <Image
          src={profilePicture}
          alt="Melnard De Jesus, fullstack web developer"
          class="h-full w-full object-cover object-top"
          widths={[320, 480, 640, 800]}
          sizes="(min-width: 768px) 45vw, 90vw"
          loading="eager"
          fetchpriority="high"
        />
      </figure>
    </div>
  </div>
</section>
