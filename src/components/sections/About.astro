---
// Visual is a styled "editor" card rather than a stock photo so the section
// ships without depending on an asset that isn't in the repo.
---

<section class="bg-bg-secondary py-16 md:py-24">
  <div class="container-page">
    <div class="grid items-center gap-10 md:grid-cols-2 lg:gap-16">
      <!-- Visual -->
      <div
        class="overflow-hidden rounded-xl border border-border bg-[#0f172a] shadow-glow-lg"
      >
        <!-- Window chrome -->
        <div
          class="flex items-center gap-2 border-b border-[#1e293b] px-4 py-3"
        >
          <span class="h-3 w-3 rounded-full bg-[#ff5f57]"></span>
          <span class="h-3 w-3 rounded-full bg-[#febc2e]"></span>
          <span class="h-3 w-3 rounded-full bg-[#28c840]"></span>
          <span class="ml-3 text-xs text-[#64748b]">developer.ts</span>
        </div>

        <!-- Snippet -->
        <pre
          class="!m-0 overflow-x-auto !rounded-none !border-0 p-5 text-[13px] leading-relaxed"><code><span class="text-[#c792ea]">const</span> <span class="text-[#82aaff]">developer</span> <span class="text-[#89ddff]">=</span> <span class="text-[#89ddff]">&#123;</span>
  <span class="text-[#f07178]">name</span><span class="text-[#89ddff]">:</span> <span class="text-[#c3e88d]">'Melnard De Jesus'</span><span class="text-[#89ddff]">,</span>
  <span class="text-[#f07178]">role</span><span class="text-[#89ddff]">:</span> <span class="text-[#c3e88d]">'Fullstack Developer'</span><span class="text-[#89ddff]">,</span>
  <span class="text-[#f07178]">stack</span><span class="text-[#89ddff]">:</span> <span class="text-[#89ddff]">[</span><span class="text-[#c3e88d]">'TypeScript'</span><span class="text-[#89ddff]">,</span> <span class="text-[#c3e88d]">'React'</span><span class="text-[#89ddff]">,</span> <span class="text-[#c3e88d]">'Node.js'</span><span class="text-[#89ddff]">]</span><span class="text-[#89ddff]">,</span>
  <span class="text-[#f07178]">location</span><span class="text-[#89ddff]">:</span> <span class="text-[#c3e88d]">'Philippines'</span><span class="text-[#89ddff]">,</span>
  <span class="text-[#f07178]">openToWork</span><span class="text-[#89ddff]">:</span> <span class="text-[#ff9cac]">true</span><span class="text-[#89ddff]">,</span>
<span class="text-[#89ddff]">&#125;</span><span class="text-[#89ddff]">;</span></code></pre>
      </div>

      <!-- Copy -->
      <div>
        <p class="eyebrow">About Me</p>
        <h2 class="mt-2 text-2xl font-bold text-white md:text-3xl">Who I Am</h2>

        <p class="mt-5 text-base leading-relaxed text-text-muted">
          I'm a self-taught fullstack developer with a passion for building
          meaningful and user-friendly web applications.
        </p>
        <p class="mt-4 text-base leading-relaxed text-text-muted">
          I enjoy turning ideas into real products and continuously learning new
          technologies to improve my craft.
        </p>

        <a
          href="/about"
          class="group mt-8 inline-flex items-center gap-2 rounded-lg bg-primary px-5 py-3 text-sm font-semibold text-primary-foreground transition-colors hover:bg-primary-hover"
        >
          Read More About Me
          <svg
            class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
