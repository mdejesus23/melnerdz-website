---
import { testimonials } from '../../data/testimonials';

// Data has no avatar images, so cards use an initials monogram instead.
const initials = (name: string) =>
  name
    .split(/\s+/)
    .map((part) => part[0])
    .join('')
    .slice(0, 2)
    .toUpperCase();

const featured = testimonials.slice(0, 3);
---

<section class="py-16 md:py-24">
  <div class="container-page">
    <!-- Section header -->
    <div
      class="mb-10 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between"
    >
      <div>
        <p class="eyebrow">Testimonials</p>
        <h2 class="mt-2 text-2xl font-bold text-white md:text-3xl">
          What People Say
        </h2>
      </div>
      <a
        href="/testimonials"
        class="group inline-flex items-center gap-2 text-sm font-medium text-white transition-colors hover:text-accent"
      >
        View all testimonials
        <svg
          class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>

    <!-- Cards -->
    <div class="grid gap-6 md:grid-cols-3">
      {
        featured.map((testimonial) => (
          <figure class="flex h-full flex-col rounded-xl border border-border bg-bg-card p-6">
            <svg
              class="h-7 w-7 shrink-0 text-border"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
            </svg>

            <blockquote class="mt-4 flex-1 text-sm leading-relaxed text-text-muted">
              {testimonial.content}
            </blockquote>

            <figcaption class="mt-6 flex items-center gap-3 border-t border-border pt-5">
              <span
                class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-accent-muted text-xs font-semibold text-accent"
                aria-hidden="true"
              >
                {initials(testimonial.name)}
              </span>
              <span class="min-w-0">
                <span class="block truncate text-sm font-semibold text-white">
                  {testimonial.name}
                </span>
                <span class="block truncate text-xs text-text-muted">
                  {testimonial.date}
                </span>
              </span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
