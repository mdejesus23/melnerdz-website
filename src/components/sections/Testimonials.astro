---
import { testimonials, TESTIMONIALS_PROFILE_URL } from '../../data/testimonials';

const total = testimonials.length;
---

<section class="py-16 md:py-24">
  <!-- Divider -->
  <div class="mb-12 flex items-center gap-4 md:mb-16">
    <div class="h-px flex-1 bg-gradient-to-r from-transparent via-border to-transparent"></div>
    <span class="rounded-full border border-border/50 bg-bg-secondary/30 px-4 py-1.5 text-[10px] font-semibold uppercase tracking-[0.15em] text-text-muted backdrop-blur-sm">Client Feedback</span>
    <div class="h-px flex-1 bg-gradient-to-r from-transparent via-border to-transparent"></div>
  </div>

  <!-- Section header -->
  <div class="mb-10 flex flex-col justify-between gap-4 md:mb-14 md:flex-row md:items-end">
    <div>
      <span class="mb-3 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.15em] text-accent-foreground">
        <span class="h-px w-8 bg-accent/50"></span>
        Testimonials
      </span>
      <h2 class="font-headfont text-3xl font-bold leading-tight md:text-4xl lg:text-5xl">
        What Clients <span class="gradient-text">Say</span>
      </h2>
    </div>
    <a
      class="group inline-flex items-center gap-2 rounded-full border border-border/50 bg-bg-secondary/30 px-4 py-2 text-sm font-medium text-text-muted backdrop-blur-sm transition-all duration-300 hover:border-accent/30 hover:text-accent"
      href="/testimonials"
    >
      View all reviews
      <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>

  <!-- Testimonial carousel -->
  <div class="testimonial-carousel" data-total={total}>
    <!-- Cards stack — CSS grid trick: all slides share the same grid cell so the
         tallest slide defines the container height. Inactive slides fade to 0. -->
    <div class="testimonial-stack rounded-2xl">
      {
        testimonials.map((testimonial, index) => (
          <article
            class="testimonial-slide mx-auto max-w-[50rem] bg-bg-card/50 p-8 backdrop-blur-sm transition-all duration-500 md:p-10 lg:p-12"
            data-index={index}
            aria-hidden={index !== 0}
          >
            <!-- Quote icon -->
            <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-full bg-accent/10">
              <svg class="h-6 w-6 text-accent" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
              </svg>
            </div>

            <!-- Content -->
            <p class="mb-8 text-base leading-relaxed text-text-muted md:text-lg lg:text-xl">
              "{testimonial.content}"
            </p>

            <!-- Author + stars -->
            <div class="flex items-center justify-between">
              <div>
                <p class="font-headfont text-lg font-semibold text-white">{testimonial.name}</p>
                <p class="mt-0.5 text-sm text-text-muted">{testimonial.date}</p>
              </div>
              <div class="flex gap-1">
                {[...Array(5)].map(() => (
                  <svg class="h-5 w-5 text-accent" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <!-- Controls -->
    <div class="mt-8 flex items-center justify-between">
      <!-- Dot indicators -->
      <div class="flex gap-2">
        {
          testimonials.map((_, i) => (
            <button
              class="testimonial-dot h-2 w-2 rounded-full border border-border/50 bg-border/50 transition-all duration-300"
              data-dot={i}
              aria-label={`Go to testimonial ${i + 1}`}
            />
          ))
        }
      </div>

      <!-- Prev / Next -->
      <div class="flex gap-3">
        <button
          class="testimonial-prev flex h-10 w-10 items-center justify-center rounded-full border border-border/50 bg-bg-secondary/50 text-text-muted backdrop-blur-sm transition-all duration-200 hover:border-accent/50 hover:bg-accent/10 hover:text-accent"
          aria-label="Previous testimonial"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button
          class="testimonial-next flex h-10 w-10 items-center justify-center rounded-full border border-border/50 bg-bg-secondary/50 text-text-muted backdrop-blur-sm transition-all duration-200 hover:border-accent/50 hover:bg-accent/10 hover:text-accent"
          aria-label="Next testimonial"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- CTA to view real testimonials -->
  <div class="mt-10 text-center">
    <a
      href={TESTIMONIALS_PROFILE_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="group inline-flex items-center gap-2 text-sm font-medium text-text-muted transition-colors hover:text-accent"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
      <span class="relative">
        View verified reviews on OnlineJobs.ph
        <span class="absolute -bottom-0.5 left-0 h-px w-0 bg-accent transition-all duration-300 group-hover:w-full"></span>
      </span>
    </a>
  </div>
</section>

<script>
  function initTestimonialCarousel() {
    document.querySelectorAll<HTMLElement>('.testimonial-carousel').forEach((carousel) => {
      const total = parseInt(carousel.dataset.total ?? '0', 10);
      if (total < 2) {
        // With a single item just show it
        carousel.querySelector<HTMLElement>('.testimonial-slide')?.classList.add('active');
        return;
      }

      const slides = carousel.querySelectorAll<HTMLElement>('.testimonial-slide');
      const dots = carousel.querySelectorAll<HTMLElement>('.testimonial-dot');
      const prevBtn = carousel.querySelector<HTMLButtonElement>('.testimonial-prev');
      const nextBtn = carousel.querySelector<HTMLButtonElement>('.testimonial-next');

      let current = 0;

      function goTo(index: number) {
        // Infinite loop wrap
        const next = ((index % total) + total) % total;

        slides[current].classList.remove('active');
        slides[current].setAttribute('aria-hidden', 'true');
        dots[current].classList.remove('active-dot');

        current = next;

        slides[current].classList.add('active');
        slides[current].setAttribute('aria-hidden', 'false');
        dots[current].classList.add('active-dot');
      }

      // Init first slide
      goTo(0);

      prevBtn?.addEventListener('click', () => goTo(current - 1));
      nextBtn?.addEventListener('click', () => goTo(current + 1));

      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => goTo(i));
      });

      // Keyboard
      carousel.setAttribute('tabindex', '0');
      carousel.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') goTo(current - 1);
        if (e.key === 'ArrowRight') goTo(current + 1);
      });

      // Touch swipe
      let touchStartX = 0;
      carousel.addEventListener('touchstart', (e) => {
        touchStartX = e.changedTouches[0].screenX;
      }, { passive: true });
      carousel.addEventListener('touchend', (e) => {
        const diff = touchStartX - e.changedTouches[0].screenX;
        if (Math.abs(diff) > 50) goTo(current + (diff > 0 ? 1 : -1));
      });
    });
  }

  initTestimonialCarousel();
  document.addEventListener('astro:page-load', initTestimonialCarousel);
</script>

<style>
  /* Stack all slides in the same grid cell so the tallest one sets the height */
  .testimonial-stack {
    display: grid;
  }

  .testimonial-slide {
    grid-column: 1;
    grid-row: 1;
    opacity: 0;
    transform: translateY(10px);
    pointer-events: none;
    /* keep in layout so the tallest slide defines the grid track height */
    visibility: hidden;
  }

  .testimonial-slide.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    visibility: visible;
  }

  .testimonial-dot {
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .testimonial-dot.active-dot {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    width: 1.5rem;
  }
</style>
