---
import { navLinks } from '@/data/navLinks';

const socials = [
  {
    label: 'GitHub',
    url: 'https://github.com/mdejesus23',
    path: 'M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z',
  },
  {
    label: 'LinkedIn',
    url: 'https://www.linkedin.com/in/melnard-de-jesus-279132278',
    path: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z',
  },
  {
    label: 'Facebook',
    url: 'https://www.facebook.com/dejesusmelnard',
    path: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z',
  },
];

// Split the nav into two columns, as in the design.
const half = Math.ceil(navLinks.length / 2);
const linkColumns = [navLinks.slice(0, half), navLinks.slice(half)];
---

<footer class="border-t border-border bg-bg-primary">
  <div class="container-page py-12 md:py-16">
    <div class="grid gap-10 md:grid-cols-12 md:gap-8">
      <!-- Brand -->
      <div class="md:col-span-4">
        <a
          href="/"
          class="font-logofont text-2xl font-bold tracking-tight text-white"
        >
          MJ
        </a>
        <p class="mt-3 max-w-xs text-sm leading-relaxed text-text-muted">
          Building clean, functional and impactful digital experiences.
        </p>
      </div>

      <!-- Quick links -->
      <div class="md:col-span-4">
        <h2 class="text-sm font-semibold text-white">Quick Links</h2>
        <div class="mt-4 grid grid-cols-2 gap-x-6 gap-y-3">
          {
            linkColumns.map((column) => (
              <ul class="space-y-3">
                {column.map((link) => (
                  <li>
                    <a
                      href={link.url}
                      class="text-sm text-text-muted transition-colors hover:text-accent"
                    >
                      {link.title}
                    </a>
                  </li>
                ))}
              </ul>
            ))
          }
        </div>
      </div>

      <!-- Connect -->
      <div class="md:col-span-4">
        <h2 class="text-sm font-semibold text-white">Let's Connect</h2>
        <ul class="mt-4 space-y-3 text-sm text-text-muted">
          <li>
            <a
              href="/contact"
              class="flex items-center gap-2.5 transition-colors hover:text-accent"
            >
              <svg
                class="h-4 w-4 shrink-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.8"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                />
              </svg>
              Get in touch
            </a>
          </li>
          <li class="flex items-center gap-2.5">
            <svg
              class="h-4 w-4 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            Philippines
          </li>
        </ul>

        <!-- Socials -->
        <div class="mt-5 flex items-center gap-4">
          {
            socials.map((social) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={social.label}
                class="text-text-muted transition-colors hover:text-accent"
              >
                <svg
                  class="h-[18px] w-[18px]"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d={social.path} />
                </svg>
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 border-t border-border pt-6 text-center">
      <p class="text-sm text-text-muted">
        &copy; <span id="copyright"></span> Melnard De Jesus. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<script>
  const copyRight = document.querySelector('#copyright');
  if (copyRight) copyRight.textContent = new Date().getFullYear().toString();
</script>
